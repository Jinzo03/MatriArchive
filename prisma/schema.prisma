generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Entity {
  id             String         @id @default(cuid())
  type           EntityType
  title          String
  slug           String         @unique
  summary        String?
  body           String?
  status         EntityStatus   @default(DRAFT)
  visibility     Visibility     @default(PRIVATE)
  aliases        String[]       @default([])
  tags           String[]       @default([])
  searchKeywords String[]       @default([])
  featuredImage  String?

  parentId String?
  parent   Entity?  @relation("EntityHierarchy", fields: [parentId], references: [id])
  children Entity[] @relation("EntityHierarchy")

  outgoingRelationships Relationship[] @relation("SourceEntity")
  incomingRelationships Relationship[] @relation("TargetEntity")

  revisions     EntityRevision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  @@index([type])
  @@index([title])
  @@index([slug])
  @@index([status])
  @@index([visibility])
}

model EntityRevision {
  id             String         @id @default(cuid())
  entityId       String
  entity         Entity         @relation(fields: [entityId], references: [id], onDelete: Cascade)

  version        Int
  title          String
  slug           String
  summary        String?
  body           String?
  status         EntityStatus
  visibility     Visibility
  aliases        String[]       @default([])
  tags           String[]       @default([])
  searchKeywords String[]       @default([])

  createdAt      DateTime       @default(now())

  @@index([entityId])
  @@index([version])
  @@unique([entityId, version])
}

model Relationship {
  id             String           @id @default(cuid())
  type           RelationshipType
  sourceEntityId String
  targetEntityId String
  notes          String?
  weight         Int?
  directionality String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  sourceEntity   Entity           @relation("SourceEntity", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntity   Entity           @relation("TargetEntity", fields: [targetEntityId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([sourceEntityId])
  @@index([targetEntityId])
}

enum EntityType {
  CHARACTER
  STORY
  INSTITUTION
  LOCATION
  DOCTRINE
  EVENT
  TERM
  ARTIFACT
  OTHER
}

enum EntityStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  DEPRECATED
}

enum Visibility {
  PRIVATE
  SHARED
  PUBLIC
}

enum RelationshipType {
  BELONGS_TO
  APPEARS_IN
  LOCATED_IN
  RULES_OVER
  CREATED_BY
  PRECEDES
  FOLLOWS
  OPPOSES
  SUPPORTS
  REFERENCES
  AFFILIATED_WITH
  IS_A
  PART_OF
  RELATED_TO
}
