generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Entity {
  id             String         @id @default(cuid())
  type           EntityType
  title          String
  slug           String         @unique
  summary        String?
  body           String?
  status         EntityStatus   @default(DRAFT)
  visibility     Visibility     @default(PRIVATE)
  aliases        String[]       @default([])
  tags           String[]       @default([])
  searchKeywords String[]       @default([])
  featuredImage  String?
  metadata       Json?
  
  parentId String?
  parent   Entity?  @relation("EntityHierarchy", fields: [parentId], references: [id])
  children Entity[] @relation("EntityHierarchy")

  outgoingRelationships Relationship[] @relation("SourceEntity")
  incomingRelationships Relationship[] @relation("TargetEntity")

  revisions     EntityRevision[]
  mediaLinks    EntityMedia[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  version   Int      @default(1)

  @@index([type])
  @@index([title])
  @@index([slug])
  @@index([status])
  @@index([visibility])
}

model EntityRevision {
  id             String         @id @default(cuid())
  entityId       String
  entity         Entity         @relation(fields: [entityId], references: [id], onDelete: Cascade)

  version        Int
  title          String
  slug           String
  summary        String?
  body           String?
  status         EntityStatus
  visibility     Visibility
  aliases        String[]       @default([])
  tags           String[]       @default([])
  searchKeywords String[]       @default([])

  createdAt      DateTime       @default(now())

  @@index([entityId])
  @@index([version])
  @@unique([entityId, version])
}

model Relationship {
  id             String           @id @default(cuid())
  type           RelationshipType
  sourceEntityId String
  targetEntityId String
  notes          String?
  weight         Int?
  directionality String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  sourceEntity   Entity           @relation("SourceEntity", fields: [sourceEntityId], references: [id], onDelete: Cascade)
  targetEntity   Entity           @relation("TargetEntity", fields: [targetEntityId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([sourceEntityId])
  @@index([targetEntityId])
}

enum EntityType {
  CHARACTER
  STORY
  INSTITUTION
  LOCATION
  DOCTRINE
  EVENT
  TERM
  ARTIFACT
  OTHER
}

enum EntityStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  DEPRECATED
}

enum Visibility {
  PRIVATE
  SHARED
  PUBLIC
}

enum RelationshipType {
  BELONGS_TO
  APPEARS_IN
  LOCATED_IN
  RULES_OVER
  CREATED_BY
  PRECEDES
  FOLLOWS
  OPPOSES
  SUPPORTS
  REFERENCES
  AFFILIATED_WITH
  IS_A
  PART_OF
  RELATED_TO
}

enum MediaRole {
  PORTRAIT
  COVER
  ICON
  SCENE
  GALLERY
  TIMELINE_ART
  EMBLEM
  THUMBNAIL
}

enum MediaKind {
  IMAGE
  VIDEO
  AUDIO
  OTHER
}

enum ImportJobStatus {
  DRAFT
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

enum ImportLogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

model MediaAsset {
  id        String   @id @default(cuid())
  slug      String   @unique
  type      MediaKind @default(IMAGE)
  title     String
  summary   String?
  src       String
  alt       String?
  mimeType  String?
  width     Int?
  height    Int?
  credit    String?
  tags      String[] @default([])
  metadata  Json?

  entityLinks EntityMedia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([type])
}

model EntityMedia {
  id          String    @id @default(cuid())
  entityId    String
  mediaAssetId String
  role        MediaRole
  primary     Boolean   @default(false)
  sortOrder   Int       @default(0)
  alt         String?

  entity      Entity     @relation(fields: [entityId], references: [id], onDelete: Cascade)
  mediaAsset  MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityId, mediaAssetId, role])
  @@index([entityId])
  @@index([mediaAssetId])
  @@index([role])
}

model ImportJob {
  id            String          @id @default(cuid())
  packageId     String
  packageVersion String
  title         String
  sourcePath    String?
  status        ImportJobStatus @default(DRAFT)
  dryRun        Boolean         @default(true)

  createdCount  Int             @default(0)
  updatedCount  Int             @default(0)
  skippedCount  Int             @default(0)
  failedCount   Int             @default(0)

  startedAt     DateTime        @default(now())
  finishedAt    DateTime?
  summary       Json?

  logs          ImportLog[]

  @@index([packageId])
  @@index([status])
  @@index([startedAt])
}

model ImportLog {
  id          String         @id @default(cuid())
  importJobId String
  level       ImportLogLevel @default(INFO)
  stage       String?
  message     String
  entitySlug  String?
  details     Json?
  createdAt   DateTime       @default(now())

  importJob   ImportJob      @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([importJobId])
  @@index([level])
  @@index([stage])
}